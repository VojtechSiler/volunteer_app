# Copy this file to ".env" and fill in the values, then restart `npm run dev`.

# --- Supabase (auth + saved candidates) ---
# Project Settings → API in your Supabase dashboard.
# Use the PUBLIC "anon"/"publishable" key here — NEVER the service_role/secret key.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# --- OpenAI (optional, for AI CV extraction) ---
# Without a key the app falls back to an offline parser.
# NOTE: for a deployed site, move this to a server/Edge Function — a browser key is prototype-only.
VITE_OPENAI_API_KEY=
VITE_OPENAI_MODEL=gpt-4o-mini
